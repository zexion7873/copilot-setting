#!/usr/bin/env bash
# Pre-commit hook: run STYLE-GUIDE validation when .github/ markdown changes
# are staged.  ('.github/*.md' in git pathspec semantics matches every depth,
# including the top-level files; deletions count too — removing a file is the
# change most likely to break cross-references.)
set -euo pipefail

STAGED_MD=$(git diff --cached --name-only --diff-filter=ACMRD -- '.github/*.md' 2>/dev/null || true)
[ -z "$STAGED_MD" ] && exit 0

echo ".github/ markdown changed — running STYLE-GUIDE validation..."
if ! bash "$(git rev-parse --show-toplevel)/.github/scripts/validate-style-guide.sh"; then
  echo ""
  echo "STYLE-GUIDE validation failed. Fix the errors above before committing."
  exit 1
fi
